---
import Layout from '../layouts/Layout.astro';
import TopNav from '../components/TopNav.astro';
---
<Layout title="Classroom Clarity - Document Library" bodyClass="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display antialiased min-h-screen flex flex-col">
    <TopNav currentPath="/library" />

    <main class="flex-1 flex flex-col p-4 md:p-8">
        <div class="max-w-7xl mx-auto w-full flex flex-col gap-6">
            <!-- Header -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div>
                    <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Document Library</h1>
                    <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Manage the source materials for AI-powered Q&A.</p>
                </div>
                <a href="/upload" class="flex items-center justify-center gap-2 rounded-lg bg-primary hover:bg-primary-dark text-white px-5 py-2.5 text-sm font-medium shadow-sm shadow-primary/25 transition-all active:scale-95 whitespace-nowrap">
                    <span class="material-symbols-outlined text-[20px]">upload_file</span>
                    Upload Document
                </a>
            </div>

            <!-- Limits info banner -->
            <div id="limits-banner" class="hidden flex flex-wrap items-center gap-4 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 px-4 py-3 text-sm">
                <div class="flex items-center gap-1.5 text-slate-600 dark:text-slate-300">
                    <span class="material-symbols-outlined text-[18px] text-primary">info</span>
                    <span id="limits-doc-count"></span>
                </div>
                <div class="w-24 h-1.5 rounded-full bg-slate-200 dark:bg-slate-700 overflow-hidden">
                    <div id="limits-progress" class="h-full rounded-full bg-primary transition-all"></div>
                </div>
                <div class="flex items-center gap-1.5 text-slate-500 dark:text-slate-400">
                    <span class="material-symbols-outlined text-[18px]">schedule</span>
                    <span id="limits-retention"></span>
                </div>
            </div>

            <!-- Search + Sort -->
            <div class="flex flex-col sm:flex-row gap-4 justify-between items-center">
                <div class="relative w-full sm:max-w-md group">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                        <span class="material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors">search</span>
                    </div>
                    <input
                        id="search-input"
                        class="block w-full rounded-lg border-0 py-3 pl-10 pr-3 text-slate-900 dark:text-white bg-white dark:bg-slate-800 ring-1 ring-inset ring-slate-200 dark:ring-slate-700 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6 shadow-sm transition-all"
                        placeholder="Search documents by title..."
                        type="text"
                    />
                </div>
                <div class="flex items-center gap-2 w-full sm:w-auto">
                    <span class="text-sm text-slate-500 dark:text-slate-400 whitespace-nowrap">Sort by:</span>
                    <div class="relative w-full sm:w-48">
                        <select id="sort-select" class="block w-full appearance-none rounded-lg border-0 bg-white dark:bg-slate-800 py-2.5 pl-3 pr-10 text-slate-900 dark:text-white ring-1 ring-inset ring-slate-200 dark:ring-slate-700 focus:ring-2 focus:ring-primary sm:text-sm sm:leading-6 shadow-sm cursor-pointer">
                            <option value="newest">Date Added (Newest)</option>
                            <option value="oldest">Date Added (Oldest)</option>
                            <option value="title">Title (A-Z)</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-slate-500">
                            <span class="material-symbols-outlined text-sm">expand_more</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Documents table -->
            <div id="table-container" class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse" id="documents-table">
                        <thead>
                            <tr class="border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50">
                                <th class="px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider w-1/3" scope="col">Title</th>
                                <th class="px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider" scope="col">Filename</th>
                                <th class="px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right" scope="col">Page Count</th>
                                <th class="px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider" scope="col">Status</th>
                                <th class="px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider" scope="col">Upload Date</th>
                                <th class="px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right" scope="col">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Empty state -->
            <div id="empty-state" class="hidden flex flex-col items-center justify-center py-16 text-center">
                <div class="size-16 rounded-2xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center mb-4">
                    <span class="material-symbols-outlined text-slate-400 text-3xl">folder_open</span>
                </div>
                <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">No documents yet</h3>
                <p class="text-slate-500 dark:text-slate-400 mb-4 max-w-sm">Upload PDF documents to start using AI-powered Q&A.</p>
                <a href="/upload" class="flex items-center gap-2 bg-primary hover:bg-primary-dark text-white px-5 py-2.5 rounded-lg text-sm font-medium shadow-sm transition-all">
                    <span class="material-symbols-outlined text-[20px]">upload_file</span>
                    Upload Document
                </a>
            </div>

            <!-- Loading state -->
            <div id="loading-state" class="flex items-center justify-center py-16">
                <span class="material-symbols-outlined animate-spin text-primary text-3xl">progress_activity</span>
            </div>
        </div>
    </main>

<script>
    const tbody = document.querySelector('#documents-table tbody') as HTMLTableSectionElement;
    const tableContainer = document.getElementById('table-container')!;
    const emptyState = document.getElementById('empty-state')!;
    const loadingState = document.getElementById('loading-state')!;

    async function loadDocuments() {
        try {
            const response = await fetch('/api/v1/documents');
            const data = await response.json();

            loadingState.classList.add('hidden');

            if (data?.content && data.content.length > 0) {
                tableContainer.classList.remove('hidden');
                emptyState.classList.add('hidden');
                renderDocuments(data.content);
            } else {
                tableContainer.classList.add('hidden');
                emptyState.classList.remove('hidden');
            }
        } catch (e) {
            console.error('Failed to load documents', e);
            loadingState.classList.add('hidden');
            tableContainer.classList.add('hidden');
            emptyState.classList.remove('hidden');
        }
    }

    function renderDocuments(docs: any[]) {
        tbody.innerHTML = docs.map(doc => `
            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                <td class="px-6 py-4 align-middle">
                    <div class="flex items-center gap-3">
                        <div class="flex-shrink-0 size-8 rounded bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 flex items-center justify-center">
                            <span class="material-symbols-outlined text-[20px]">picture_as_pdf</span>
                        </div>
                        <span class="font-medium text-slate-900 dark:text-white">${doc.title || doc.filename}</span>
                    </div>
                </td>
                <td class="px-6 py-4 align-middle text-sm text-slate-500 dark:text-slate-400 font-mono">${doc.filename}</td>
                <td class="px-6 py-4 align-middle text-sm text-slate-600 dark:text-slate-300 text-right">${doc.pageCount || '-'}</td>
                <td class="px-6 py-4 align-middle">
                    <span class="inline-flex items-center gap-1.5 rounded-full ${doc.status === 'COMPLETED' ? 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400' : 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400'} px-2.5 py-1 text-xs font-medium">
                        ${doc.status}
                    </span>
                </td>
                <td class="px-6 py-4 align-middle text-sm text-slate-500 dark:text-slate-400">${new Date(doc.createdAt).toLocaleDateString()}</td>
                <td class="px-6 py-4 align-middle text-right">
                    <button onclick="deleteDocument('${doc.id}')" class="text-slate-400 hover:text-red-500 transition-colors p-1.5 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg" title="Delete">
                        <span class="material-symbols-outlined text-[20px]">delete</span>
                    </button>
                </td>
            </tr>
        `).join('');
    }

    // Expose delete function globally
    (window as any).deleteDocument = async function(id: string) {
        if (!confirm('Are you sure you want to delete this document?')) return;
        try {
            const resp = await fetch(`/api/v1/documents/${id}`, { method: 'DELETE' });
            if (resp.ok) loadDocuments();
        } catch (e) {
            console.error('Failed to delete document', e);
        }
    };

    async function loadLimits() {
        try {
            const resp = await fetch('/api/v1/limits');
            if (!resp.ok) return;
            const data = await resp.json();
            const { currentCount, maxCount, retentionDays } = data.documents;

            const banner = document.getElementById('limits-banner')!;
            document.getElementById('limits-doc-count')!.textContent = `${currentCount} of ${maxCount} documents`;
            document.getElementById('limits-retention')!.textContent = `Auto-delete after ${retentionDays} days`;

            const pct = Math.min((currentCount / maxCount) * 100, 100);
            const progress = document.getElementById('limits-progress')! as HTMLElement;
            progress.style.width = `${pct}%`;
            if (pct >= 90) progress.classList.replace('bg-primary', 'bg-red-500');
            else if (pct >= 70) progress.classList.replace('bg-primary', 'bg-amber-500');

            banner.classList.remove('hidden');
        } catch (e) {
            // Limits banner is optional — fail silently
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        loadDocuments();
        loadLimits();
    });
</script>
</Layout>
