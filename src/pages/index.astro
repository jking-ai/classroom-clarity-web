---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Classroom Clarity - AI Q&A" bodyClass="bg-white dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 min-h-screen flex antialiased overflow-hidden">
    <aside class="w-64 bg-sidebar-bg dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 flex flex-col h-screen shrink-0">
        <div class="p-6 pb-2">
            <div class="flex items-center gap-3 text-slate-900 dark:text-white mb-8">
                <div class="size-8 text-primary flex items-center justify-center bg-primary/10 rounded-lg">
                    <span class="material-symbols-outlined text-2xl">school</span>
                </div>
                <h2 class="text-lg font-bold leading-tight tracking-tight">Classroom Clarity</h2>
            </div>
            <button class="w-full flex items-center justify-center gap-2 rounded-xl h-11 px-4 bg-accent-amber hover:bg-amber-600 transition-colors text-white text-sm font-bold shadow-md shadow-amber-500/20 mb-6">
                <span class="material-symbols-outlined text-[20px]">add</span>
                New Study Session
            </button>
        </div>
        <nav class="flex-1 px-3 overflow-y-auto space-y-1">
            <div class="text-xs font-bold text-slate-400 uppercase tracking-wider px-3 py-2 mb-1">Menu</div>
            <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-white dark:bg-slate-800 text-primary font-medium shadow-sm border border-slate-200/50 dark:border-slate-700" href="/">
                <span class="material-symbols-outlined text-[20px]">chat_bubble</span>
                Current Chat
            </a>
            <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200 transition-colors" href="#">
                <span class="material-symbols-outlined text-[20px]">history</span>
                History
            </a>
            <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200 transition-colors" href="/library">
                <span class="material-symbols-outlined text-[20px]">folder</span>
                Documents
            </a>
            <div class="mt-8 text-xs font-bold text-slate-400 uppercase tracking-wider px-3 py-2 mb-1">Recent Sessions</div>
            <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200 transition-colors text-sm truncate" href="#">
                <span class="material-symbols-outlined text-[18px]">schedule</span>
                Calculus Midterm Prep
            </a>
            <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200 transition-colors text-sm truncate" href="#">
                <span class="material-symbols-outlined text-[18px]">schedule</span>
                History Essay Outline
            </a>
        </nav>
        <div class="p-4 border-t border-slate-200 dark:border-slate-800">
            <div class="flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 cursor-pointer transition-colors">
                <div class="bg-center bg-no-repeat bg-cover rounded-full size-9 border border-slate-200 dark:border-slate-600" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuC5mZxndj11INDGG1HzWPWZ7FQmKHGmcBjXpUxLhmJGvooDk5u3lIBG-bXqTqraN7i7s5CLuqggR7ALmAXUzDjrmM7D_yH8e_Z21F0Oyu-8vGm_T9P0r3hrjZOgb3Otm6vQoG3ZqPHDuekxwU6KCvqJgOcpGhfboa76C39oNk7-PcDSLKiTrcZ_puYnKxup8ecUjVXEtGD5UuJi073bMsrfuk1bsoB-yc2qeVMjibcBu0pkgP-SID7O6kItUxFrCR14mTQ_cT5akVYb");'></div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-slate-900 dark:text-white truncate">Alex Student</p>
                    <p class="text-xs text-slate-500 truncate">Free Plan</p>
                </div>
                <span class="material-symbols-outlined text-slate-400">settings</span>
            </div>
        </div>
    </aside>
    <main class="flex-1 flex flex-col h-screen relative bg-white dark:bg-background-dark">
        <header class="h-16 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between px-8 bg-white/80 dark:bg-background-dark/80 backdrop-blur-sm z-10">
            <h1 class="font-semibold text-slate-700 dark:text-slate-200">Attendance Policy Q&amp;A</h1>
            <div class="flex items-center gap-2">
                <button class="text-slate-400 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined">share</span>
                </button>
                <button class="text-slate-400 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined">more_horiz</span>
                </button>
            </div>
        </header>
        <div class="flex-1 overflow-y-auto p-8 pb-32">
            <div class="max-w-3xl mx-auto space-y-8">
                <div class="flex justify-end">
                    <div class="bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-slate-100 rounded-2xl rounded-tr-sm px-6 py-4 max-w-[80%] shadow-sm">
                        <p class="text-lg">What is the attendance policy?</p>
                    </div>
                    <div class="ml-4 mt-1 size-8 rounded-full bg-cover bg-center shrink-0 border border-slate-200" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuC5mZxndj11INDGG1HzWPWZ7FQmKHGmcBjXpUxLhmJGvooDk5u3lIBG-bXqTqraN7i7s5CLuqggR7ALmAXUzDjrmM7D_yH8e_Z21F0Oyu-8vGm_T9P0r3hrjZOgb3Otm6vQoG3ZqPHDuekxwU6KCvqJgOcpGhfboa76C39oNk7-PcDSLKiTrcZ_puYnKxup8ecUjVXEtGD5UuJi073bMsrfuk1bsoB-yc2qeVMjibcBu0pkgP-SID7O6kItUxFrCR14mTQ_cT5akVYb");'></div>
                </div>
                <div class="flex items-start gap-4">
                    <div class="size-10 rounded-full bg-gradient-to-br from-primary to-teal-500 flex items-center justify-center shrink-0 shadow-lg shadow-primary/20 mt-1">
                        <span class="material-symbols-outlined text-white">smart_toy</span>
                    </div>
                    <div class="flex-1 space-y-6">
                        <div class="prose-custom text-slate-700 dark:text-slate-300 text-base leading-relaxed">
                            <p>
                                According to the <strong>Student Handbook 2024</strong>, the attendance policy is strict but allows for some flexibility. Here are the key points you need to know:
                            </p>
                            <ul>
                                <li>Students are allowed <strong>3 unexcused absences</strong> per semester. Beyond this limit, grade penalties will apply.</li>
                                <li>Each unexcused absence exceeding the limit results in a <strong>2% deduction</strong> from your final grade.</li>
                                <li><strong>Participation</strong>, which includes regular attendance, accounts for <strong>10% of the total final grade</strong>.</li>
                            </ul>
                            <p>
                                Please note that exceptions are made for medical emergencies if valid documentation is provided within 48 hours of the absence.
                            </p>
                        </div>
                        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-4 border border-slate-100 dark:border-slate-800">
                            <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-3 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[16px]">library_books</span>
                                Sources Used
                            </h4>
                            <div class="flex gap-4 overflow-x-auto pb-2 scrollbar-hide">
                                <div class="w-64 shrink-0 bg-white dark:bg-slate-800 rounded-lg p-3 shadow-sm border border-slate-200 dark:border-slate-700 hover:border-primary/50 cursor-pointer transition-colors group">
                                    <div class="flex items-start gap-3">
                                        <div class="size-8 rounded bg-red-50 dark:bg-red-900/20 text-red-500 flex items-center justify-center shrink-0">
                                            <span class="material-symbols-outlined text-[20px]">picture_as_pdf</span>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <h5 class="text-sm font-semibold text-slate-900 dark:text-white truncate group-hover:text-primary transition-colors">Student Handbook 2024</h5>
                                            <p class="text-xs text-slate-500 mt-0.5">Page 12 • "Absence Policy"</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="w-64 shrink-0 bg-white dark:bg-slate-800 rounded-lg p-3 shadow-sm border border-slate-200 dark:border-slate-700 hover:border-primary/50 cursor-pointer transition-colors group">
                                    <div class="flex items-start gap-3">
                                        <div class="size-8 rounded bg-blue-50 dark:bg-blue-900/20 text-blue-500 flex items-center justify-center shrink-0">
                                            <span class="material-symbols-outlined text-[20px]">description</span>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <h5 class="text-sm font-semibold text-slate-900 dark:text-white truncate group-hover:text-primary transition-colors">Math 101 Syllabus</h5>
                                            <p class="text-xs text-slate-500 mt-0.5">Page 2 • "Grading"</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <button class="flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-primary transition-colors px-2 py-1 rounded hover:bg-slate-50 dark:hover:bg-slate-800">
                                <span class="material-symbols-outlined text-[18px]">content_copy</span> Copy
                            </button>
                            <button class="flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-primary transition-colors px-2 py-1 rounded hover:bg-slate-50 dark:hover:bg-slate-800">
                                <span class="material-symbols-outlined text-[18px]">thumb_up</span> Helpful
                            </button>
                            <button class="flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-primary transition-colors px-2 py-1 rounded hover:bg-slate-50 dark:hover:bg-slate-800">
                                <span class="material-symbols-outlined text-[18px]">autorenew</span> Regenerate
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-white via-white to-transparent dark:from-background-dark dark:via-background-dark z-20">
            <div class="max-w-3xl mx-auto">
                <div class="relative group">
                    <div class="absolute bottom-full mb-2 left-0 flex gap-2">
                        <button class="text-xs bg-primary/10 hover:bg-primary/20 text-primary-dark dark:text-primary-light px-3 py-1.5 rounded-full transition-colors font-medium border border-transparent hover:border-primary/30">
                            Tell me more about medical exceptions
                        </button>
                        <button class="text-xs bg-primary/10 hover:bg-primary/20 text-primary-dark dark:text-primary-light px-3 py-1.5 rounded-full transition-colors font-medium border border-transparent hover:border-primary/30">
                            How do I report an absence?
                        </button>
                    </div>
                    <form action="/api/v1/query" method="POST" id="query-form" class="relative shadow-xl shadow-slate-200/50 dark:shadow-black/20 rounded-2xl bg-white dark:bg-slate-800 ring-1 ring-slate-200 dark:ring-slate-700 focus-within:ring-2 focus-within:ring-primary transition-all">
                        <textarea name="question" class="block w-full rounded-2xl border-0 py-4 pl-4 pr-14 text-slate-900 dark:text-white placeholder:text-slate-400 focus:ring-0 sm:text-base sm:leading-6 bg-transparent resize-none" placeholder="Ask a follow-up question..." rows="1"></textarea>
                        <div class="absolute bottom-2 right-2 flex items-center gap-1">
                            <button type="button" class="p-2 rounded-lg text-slate-400 hover:text-primary hover:bg-primary/10 transition-colors" title="Attach file">
                                <span class="material-symbols-outlined text-[20px]">attach_file</span>
                            </button>
                            <button type="submit" class="p-2 rounded-lg bg-primary hover:bg-primary-dark text-white transition-colors shadow-md shadow-primary/20">
                                <span class="material-symbols-outlined text-[20px]">send</span>
                            </button>
                        </div>
                    </form>
                    <p class="text-center text-xs text-slate-400 mt-3">
                        Classroom Clarity AI can make mistakes. Please verify important info.
                    </p>
                </div>
            </div>
        </div>
    </main>
</Layout>
